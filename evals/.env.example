# OpenRouter API key (required for promptfoo evals)
OPENROUTER_API_KEY=your-openrouter-api-key

# Optional model override (also read from OPENROUTER_MODEL when set)
OPENROUTER_MODEL=google/gemini-3.1-flash-lite-preview

# Vision model for image search evals (interpretImageQuery)
OPENROUTER_VISION_MODEL=google/gemini-3.1-flash-lite-preview

# Voice audio evals (interpretVoiceAudio via OpenRouter input_audio)
OPENROUTER_VOICE_MODEL=google/gemini-2.5-flash

# AWS Bedrock (optional — Bedrock matrix columns skip when unset)
AWS_REGION=eu-west-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_VISION_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# Optional: API key for Promptfoo redteam attack generation (defaults to remote generator)
# REDTEAM_PROVIDER_API_KEY=your-openai-or-openrouter-key
