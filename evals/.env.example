# OpenRouter API key (required for promptfoo evals)
OPENROUTER_API_KEY=your-openrouter-api-key

# Optional model override (also read from OPENROUTER_MODEL when set)
OPENROUTER_MODEL=google/gemini-3.1-flash-lite-preview

# Voice audio evals (interpretVoiceAudio via OpenRouter input_audio)
OPENROUTER_VOICE_MODEL=google/gemini-2.5-flash

# Image search evals (interpretImageQuery via OpenRouter vision)
OPENROUTER_VISION_MODEL=google/gemini-3.1-flash-lite-preview
