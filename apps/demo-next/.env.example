# Commercetools
CTP_PROJECT_KEY=your-project-key
CTP_CLIENT_ID=your-client-id
CTP_CLIENT_SECRET=your-client-secret
CTP_REGION=europe-west1.gcp

# AI Provider: openrouter | bedrock
CAT_AI_PROVIDER=openrouter
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=google/gemini-3.1-flash-lite-preview
OPENROUTER_VISION_MODEL=google/gemini-3.1-flash-lite-preview
OPENROUTER_VOICE_MODEL=google/gemini-2.5-flash

# AWS Bedrock (when CAT_AI_PROVIDER=bedrock)
# AWS_REGION=us-east-1
# BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
# BEDROCK_VISION_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# Voice: openrouter-audio (default with OpenRouter) | elevenlabs-stt
# CAT_VOICE_MODE=openrouter-audio

# ElevenLabs (TTS for voice summary; STT only when CAT_VOICE_MODE=elevenlabs-stt)
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_STT_MODEL=scribe_v2
ELEVENLABS_TTS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2

# Defaults
# Language products are indexed in commercetools (must match project languages)
CAT_CATALOG_LOCALE=no
CAT_DEFAULT_CURRENCY=NOK
CAT_DEFAULT_LIMIT=20

# Deprecated: use CAT_CATALOG_LOCALE instead
# CAT_DEFAULT_LOCALE=en

# Dev tracing (logs search pipeline and commercetools requests)
# CAT_DEBUG=true

# Langfuse AI observability (opt-in; both keys required)
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
# Self-host or other regions: https://us.cloud.langfuse.com, etc.
# LANGFUSE_TRACE_SUGGESTIONS=true  # optional; autocomplete spans are off by default
# Managed system prompts (opt-in; requires keys above + sync script)
# LANGFUSE_PROMPTS=true
# LANGFUSE_PROMPT_LABEL=production
# LANGFUSE_PROMPT_CACHE_TTL_SECONDS=60
# Sync local catalog → Langfuse staging: pnpm sync:langfuse-prompts
# Promote after evals: pnpm sync:langfuse-prompts -- --label production

# Optional short-lived search cache (in-memory per process; not shared across instances)
# CAT_CACHE_ENABLED=true
# CAT_CACHE_TTL_MS=60000
# CAT_CACHE_MAX_ENTRIES=500
# Caches text search, interpreted queries, suggestions, voice (full audio hash), and image search.

# Optional schema-driven faceted search (Product Type attributes must be isSearchable)
# CAT_FACETS_ENABLED=true
# CAT_FACET_SCHEMA_TTL_MS=600000
# CAT_FACET_INCLUDE=color,size,height
# CAT_FACET_EXCLUDE=internalCode
# CAT_FACET_MAX_ATTRIBUTES=12

# Autocomplete uses commercetools Search Term Suggestions (requires Product Projection Search
# and SearchKeywords configured in your project). Enable in the widget with enableAutocomplete.

# Demo widget (optional client-side locale overrides)
# NEXT_PUBLIC_CAT_CATALOG_LOCALE=no
# NEXT_PUBLIC_CAT_QUERY_LOCALE=en
