# Commercetools
CTP_PROJECT_KEY=your-project-key
CTP_CLIENT_ID=your-client-id
CTP_CLIENT_SECRET=your-client-secret
CTP_REGION=europe-west1.gcp

# AI Provider: openrouter | bedrock
CAT_AI_PROVIDER=openrouter
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=google/gemini-2.0-flash-001
OPENROUTER_VISION_MODEL=google/gemini-2.0-flash-001

# AWS Bedrock (when CAT_AI_PROVIDER=bedrock)
# AWS_REGION=us-east-1
# BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
# BEDROCK_VISION_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# ElevenLabs (voice STT + TTS)
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_STT_MODEL=scribe_v2
ELEVENLABS_TTS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2

# Defaults
# Language products are indexed in commercetools (must match project languages)
CAT_CATALOG_LOCALE=no
CAT_DEFAULT_CURRENCY=NOK
CAT_DEFAULT_LIMIT=20

# Deprecated: use CAT_CATALOG_LOCALE instead
# CAT_DEFAULT_LOCALE=en

# Dev tracing (logs search pipeline and commercetools requests)
# CAT_DEBUG=true

# Demo widget (optional client-side locale overrides)
# NEXT_PUBLIC_CAT_CATALOG_LOCALE=no
# NEXT_PUBLIC_CAT_QUERY_LOCALE=en
