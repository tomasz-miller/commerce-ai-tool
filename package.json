{
  "name": "commerce-ai-tool",
  "version": "1.0.0",
  "private": true,
  "description": "AI-powered commercetools search plugin for React, Next.js, and Angular",
  "license": "MIT",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test && vitest run evals",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "eval:promptfoo": "pnpm build && promptfoo eval -c evals/promptfooconfig.ts",
    "eval:promptfoo:voice": "pnpm build && promptfoo eval -c evals/promptfooconfig.voice.ts",
    "eval:promptfoo:image": "pnpm build && promptfoo eval -c evals/promptfooconfig.image.ts",
    "eval:promptfoo:voice-enhance": "pnpm build && promptfoo eval -c evals/promptfooconfig.voice-enhance.yaml",
    "eval:promptfoo:voice-tts": "pnpm build && promptfoo eval -c evals/promptfooconfig.voice-tts.yaml",
    "eval:promptfoo:redteam": "pnpm build && promptfoo redteam run -c evals/promptfooconfig.redteam.yaml",
    "eval:promptfoo:redteam:generate": "pnpm build && promptfoo redteam generate -c evals/promptfooconfig.redteam.yaml",
    "eval:promptfoo:view": "promptfoo view",
    "eval:fixtures:audio": "bash evals/scripts/generate-audio-fixtures.sh",
    "eval:fixtures:images": "bash evals/scripts/compress-image-fixtures.sh"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.0",
    "@commerce-ai-tool/core": "workspace:*",
    "@eslint/js": "^9.22.0",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "promptfoo": "^0.120.4",
    "turbo": "^2.4.4",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.0.9"
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24"
  }
}
